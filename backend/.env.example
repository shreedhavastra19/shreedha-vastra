# ================================================================
# Shreedha Vastra — Backend Environment Variables (TEMPLATE)
# ================================================================
# Copy this file to ".env" in the same folder, then fill in your
# own real values. NEVER commit the actual ".env" file to git —
# it's already excluded via .gitignore.
# ================================================================

# ---------- Server ----------
# Port the Express server runs on
PORT=5000

# "development" while building locally, "production" once deployed
NODE_ENV=development

# The URL of your frontend app (used for CORS + email links)
# Local dev example: http://localhost:5173
# Production example: https://shreedhavastra.in
CLIENT_URL=http://localhost:5173


# ---------- Database (MongoDB) ----------
# Get this from MongoDB Atlas (free tier): https://www.mongodb.com/cloud/atlas
# Format: mongodb+srv://<username>:<password>@<cluster-url>/<database-name>
MONGO_URI=mongodb+srv://your_username:your_password@your-cluster.mongodb.net/shreedha-vastra


# ---------- Authentication (JWT) ----------
# A long, random, secret string used to sign login tokens.
# Generate one with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_this_with_a_long_random_secret_string

# How long a login session stays valid
JWT_EXPIRES_IN=7d

# Name of the cookie that stores the JWT in the browser
JWT_COOKIE_NAME=shreedha_token


# ---------- Cloudinary (Product Image Hosting) ----------
# Get these from your Cloudinary dashboard: https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret


# ---------- Razorpay (Payments) ----------
# Get test keys from: https://dashboard.razorpay.com/app/keys
# Use TEST keys while developing, LIVE keys only in production
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret


# ---------- Email (Nodemailer) ----------
# Used for order confirmations, password reset emails, etc.
# Example using Gmail SMTP (use an "App Password", not your real Gmail password)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_app_specific_password
EMAIL_FROM_NAME=Shreedha Vastra
EMAIL_FROM_ADDRESS=no-reply@shreedhavastra.in


# ---------- Admin Seeding (used once, by utils/seeder.js) ----------
# Creates the first admin account when you run "npm run seed"
ADMIN_EMAIL=admin@shreedhavastra.in
ADMIN_PASSWORD=change_this_before_seeding
