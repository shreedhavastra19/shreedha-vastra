# ================================================================
# Shreedha Vastra — Frontend Environment Variables (TEMPLATE)
# ================================================================
# Copy this file to ".env" and fill in real values.
# Vite only exposes variables prefixed with VITE_ to the browser.
# ================================================================

# Backend API base URL.
# Local dev: leave as /api (Vite proxies it to localhost:5000 — see vite.config.js)
# Production: https://api.shreedhavastra.in/api (or wherever the backend is deployed)
VITE_API_URL=/api

# Razorpay public key (safe to expose in frontend — this is the "key_id", not the secret)
VITE_RAZORPAY_KEY_ID=your_razorpay_key_id
